# Copy to .env.local and fill in values. Same keys as in the previous project.

# Supabase (required when using leads DB / storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=

# Integrations (optional – form works without; lead is still validated and submitted)
PIPEDRIVE_API_TOKEN=
# PIPEDRIVE_API_URL=  # optional, defaults to https://api.pipedrive.com/v1
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

# Cloudflare Turnstile (optional – if set, CAPTCHA is required on step 6)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: set to "telegram" to run only Telegram (CRM, Slack, DB skipped)
# ENABLE_LEAD_INTEGRATIONS=all
